= 时间表和里程碑

#import "../../style/table.typ": orange-grid-table

#orange-grid-table(
  columns: (auto, 1fr, 1fr),
  table-align: (center + horizon, left + horizon, left + horizon),
  [*时间*],
  [*关键任务*],
  [*里程碑指标*],
  table.hline(stroke: 0.5pt),
  [第 1—2 个月],
  [完成用户访谈、问卷调研、竞品拆解和商业计划书定稿。],
  [形成 30 份访谈记录、1 个 App 低保真原型。],
  [第 3—4 个月],
  [完成软件 MVP：对话、情绪记录、FriendSkill 风格卡片、消息建议。],
  [完成 50 名种子用户测试，7 日留存达到 30% 以上。],
  [第 5—6 个月],
  [完成硬件样机：表情屏、语音交互、触摸反馈、充电底座。],
  [完成 10 台可演示样机。],
  [第 7—9 个月],
  [校园试点：宿舍、自习室、社团、心理健康活动。],
  [100—300 台试用，收集日活、留存和付费意愿。],
  [第 10—12 个月],
  [产品迭代、众筹预售、供应链评估。],
  [完成首批 1,000 台预售或意向订单。],
  [第 2 年],
  [进入量产和城市青年市场，启动 B2B 校园/企业合作。],
  [销量 15,000 台，收入超 1,000 万元。],
  [第 3 年],
  [扩展 IP 联名和企业服务，形成品牌矩阵。],
  [销量 60,000 台，收入超 5,000 万元。],
)
